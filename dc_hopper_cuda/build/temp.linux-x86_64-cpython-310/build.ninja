build /home/lishengping/dc_triton_test/dc_triton_opt/dc_hopper_cuda/build/temp.linux-x86_64-cpython-310/dc_hopper_kernel.o: cuda_compile /home/lishengping/dc_triton_test/dc_triton_opt/dc_hopper_cuda/dc_hopper_kernel.cu








